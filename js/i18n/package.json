		"scripts",
		"inlang-settings.template.json",
		"README.md"
	],
	"peerDependencies": {
		"@inlang/paraglide-js": "^2.0.0",
		"bits-ui": "^2.0.0",
		"svelte": "^5.0.0",
		"vite": ">=5.0.0"
	},
	"peerDependenciesMeta": {
		"bits-ui": { "optional": true },
		"svelte": { "optional": true },
		"vite": { "optional": true }
	},
	"devDependencies": {
		"@inlang/paraglide-js": "^2.16.1",
		"bits-ui": "^2.18.0",
		"svelte": "^5.55.4"
	}
