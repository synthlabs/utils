{
	"name": "@synthlabs/i18n",
	"version": "0.1.0",
	"description": "Shared i18n tooling for Synth Labs apps. Wraps Paraglide JS with our standard config + helpers.",
	"private": true,
	"type": "module",
	"exports": {
		".": "./src/index.ts",
		"./locale": "./src/osLocale.ts",
		"./svelte": "./svelte/index.ts",
		"./inlang-settings": "./inlang-settings.template.json"
	},
	"bin": {
		"i18n-lint": "./scripts/lint-locales.mjs"
	},
	"files": [
